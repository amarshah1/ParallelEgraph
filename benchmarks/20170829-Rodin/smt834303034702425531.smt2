(set-option :print-success false)
(set-logic QF_UF)
(declare-fun x1 () Bool)
(declare-fun x5 () Bool)
(declare-fun x3 () Bool)
(declare-fun x4 () Bool)
(declare-fun x6 () Bool)
(declare-fun x2 () Bool)
(assert (not (or x5 x4 (and (not x6) x1) (and x1 x6) (and (not x6) x2) (and x6 x2))))
(assert x3)
(check-sat)
(exit)
